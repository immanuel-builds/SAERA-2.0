# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (MySQL Required)
DB_NAME=saera_db
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306

# Redis Configuration (for Celery)
# macOS/Linux: redis://localhost:6379/0
# Windows: install Redis via Chocolatey, Memurai, or WSL2
REDIS_URL=redis://localhost:6379/0

# Celery eager mode — controls whether scans run synchronously (no Redis needed).
#   True  = scans run in the web-server process (no Redis/worker required, Windows-friendly)
#   False = scans run in a Celery worker (Redis required)
#   auto  = auto-detect: use True when Redis is unreachable, False otherwise
# Default is True so the app works out-of-the-box on Windows without Redis.
CELERY_TASK_ALWAYS_EAGER=True

# Security Settings
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

# CVE API Configuration (optional)
NVD_API_KEY=your-nvd-api-key-here

# Rate Limiting
SCAN_RATE_LIMIT=5/hour

# Email Configuration (for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
